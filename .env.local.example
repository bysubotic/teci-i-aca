# --- Supabase ---------------------------------------------------------------
# Project URL + keys — Supabase dashboard → Project Settings → API / API Keys
NEXT_PUBLIC_SUPABASE_URL=
# Public "publishable" key (sb_publishable_…) — safe in the browser.
# (Legacy "anon" key also works: NEXT_PUBLIC_SUPABASE_ANON_KEY)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# SECRET key (sb_secret_…) — SERVER ONLY, never prefix with NEXT_PUBLIC_.
# Needed for /admin writes + the 👑 reveal + private letters.
# (Legacy "service_role" key also works: SUPABASE_SERVICE_ROLE_KEY)
SUPABASE_SECRET_KEY=

# --- Access codes (server-side only) ----------------------------------------
FAMILY_CODE=        # shared family passphrase (the gate)
ADMIN_CODE=         # parents-only code for /admin

# --- Optional ---------------------------------------------------------------
# Public site URL for share-link previews (Open Graph). On Vercel it falls back
# to VERCEL_URL automatically; locally defaults to localhost.
NEXT_PUBLIC_SITE_URL=
